  bottom: "conv2_2"
  top: "conv2_2norm"
  lrn_param {
    local_size: 5
    alpha: 0.0001
    beta: 0.75
  }
}
layer {
  name: "conv3_1"
  type: "Convolution"
  bottom: "conv2_2norm"
  top: "conv3_1"
  convolution_param {
    num_output: 256
    pad: 1
    kernel_size: 3
