layer {
  name: "data"
  type: "Input"
  top: "data_l"
  input_param {
    shape {
      dim: 1
      dim: 1
      dim: 224
      dim: 224
    }
  }
}
layer {
  name: "bw_conv1_1"
  type: "Convolution"
  bottom: "data_l"
  top: "bw_conv1_1"
  convolution_param {
    num_output: 64
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "relu1_1"
  type: "ReLU"
  bottom: "bw_conv1_1"
  top: "bw_conv1_1"
}
layer {
  name: "bw_conv1_2"
  type: "Convolution"
  bottom: "bw_conv1_1"
  top: "bw_conv1_2"
  convolution_param {
    num_output: 64
    pad: 1
    kernel_size: 3
    stride: 2
  }
}
layer {
  name: "relu1_2"
  type: "ReLU"
  bottom: "bw_conv1_2"
  top: "bw_conv1_2"
}
layer {
  name: "conv1_2norm"
  type: "LRN"
  bottom: "bw_conv1_2"
  top: "conv1_2norm"
  lrn_param {
    local_size: 5
    alpha: 0.0001
    beta: 0.75
  }
}
layer {
  name: "conv2_1"
  type: "Convolution"
  bottom: "conv1_2norm"
  top: "conv2_1"
  convolution_param {
    num_output: 128
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "relu2_1"
